{
    "installCommand": "npm install --legacy-peer-deps",
    "buildCommand": "npm run build",
    "framework": "vite",
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/ping",
            "destination": "/api/ping.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}